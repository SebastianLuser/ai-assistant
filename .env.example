PORT=8080
GO_ENVIRONMENT=development

# AI Provider (claude or openai)
AI_PROVIDER=claude

# Claude API
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI API (optional — used when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Sheets
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_NAME=Gastos

# Google Calendar
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Webhook security
WEBHOOK_SECRET=your-random-secret

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_TO_NUMBER=5491112345678
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret-from-meta

# PostgreSQL
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DSN=postgres://jarvis:${POSTGRES_PASSWORD}@postgres:5432/jarvis?sslmode=disable

# Skills
SKILLS_DIR=skills

# Notion (optional)
NOTION_API_KEY=
NOTION_DEFAULT_PAGE_ID=

# Obsidian (optional)
OBSIDIAN_VAULT_PATH=

# GitHub (optional)
GITHUB_TOKEN=

# Jira (optional)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Spotify (optional)
SPOTIFY_ACCESS_TOKEN=

# Todoist (optional)
TODOIST_API_TOKEN=

# Gmail (optional — uses same credentials.json as Sheets/Calendar)
GMAIL_USER_EMAIL=

# ClickUp (optional)
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=

# Figma (optional)
FIGMA_ACCESS_TOKEN=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
TELEGRAM_BOT_USERNAME=

# Internal features (habits, links, finance summary, projects, budget alerts, journal)
# use existing services — no additional env vars required.
# Habits and finance cache use PostgreSQL.
# Budget alerts and daily journal use WHATSAPP_* vars.
# Finance summary and project status use CLAUDE_API_KEY.
